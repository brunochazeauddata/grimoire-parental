{
  "functions": {
    "api/*.ts": {
      "maxDuration": 10
    }
  },
  "builds": [
    {
      "src": "api/*.ts",
      "use": "@vercel/node"
    }
  ],
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/"
    }
  ],
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "framework": "vite"
}
